# MOS extraction 5V CMOS
#
extract_devices(mos4("PMOS" ), 
                            { "SD" => (MP - GC),        # S/D region
                              "G"  => (MP & GC),        # Channel region
                              "W"  => (MP & GC & WN),   # Backgate region
                              "tS" => (SDP),            # Terminal: Source
                              "tD" => (SDP),            # Terminal: Drain
                              "tG" => (GC),             # Terminal: Gate
                              "tB" => (WN) })           # Terminal: Backgate
#
tolerance("PMOS", "W", :relative => 0.01)           # 1% tolerance 
tolerance("PMOS", "L", :relative => 0.0)            # 0% tolerance 
#
extract_devices(mos4("NMOS" ), 
                            { "SD" => (MN - GC),        # S/D region
                              "G"  => (MN & GC),        # Channel region
                              "W"  => (MN & GC & BULK), # Backgate region
                              "tS" => (SDN),            # Terminal: Source
                              "tD" => (SDN),            # Terminal: Drain
                              "tG" => (GC),             # Terminal: Gate
                              "tB" => (BULK) })         # Terminal: Backgate
#
tolerance("NMOS", "W", :relative => 0.01)           # 1% tolerance 
tolerance("NMOS", "L", :relative => 0.0)            # 0% tolerance 
#
# ----- ------ ----- ----- ------ ----- ----- ------ ----- 
# MOS extraction 5V CMOS for ESD only NMOS is special
#
extract_devices(mos4("PMOS" ), 
                            { "SD" => (MPE - GC),       # S/D region
                              "G"  => (MPE & GC),       # Channel region
                              "W"  => (MPE & GC & WN),  # Backgate region
                              "tS" => (SDPE),           # Terminal: Source
                              "tD" => (SDPE),           # Terminal: Drain
                              "tG" => (GC),             # Terminal: Gate
                              "tB" => (WN) })           # Terminal: Backgate

extract_devices(mos4("NMOSE" ), 
                            { "SD" => (MNE - GC),        # S/D region
                              "G"  => (MNE & GC),        # Channel region
                              "W"  => (MNE & GC & BULK), # Backgate region
                              "tS" => (SDNE),            # Terminal: Source
                              "tD" => (SDNE),            # Terminal: Drain
                              "tG" => (GC),              # Terminal: Gate
                              "tB" => (BULK) })          # Terminal: Backgate
#
tolerance("NMOSE", "W", :relative => 0.01)            # 1% tolerance 
tolerance("NMOSE", "L", :relative => 0.0)             # 0% tolerance 
#
# ----- ------ ----- ----- ------ ----- ----- ------ ----- 
# DIODE extraction
#
extract_devices(diode("DP"), 
                            { "P"  => (DP),           # P region
                              "N"  => (DP & WN),      # N region
                              "tA" => (DP),           # Terminal: Anode
                              "tC" => (WN) })         # Terminal: Cathode
#                              
tolerance("DP", "A", :relative => 0.05)               # 5% tolerance 
tolerance("DP", "P", :relative => 0.05)               # 5% tolerance 
#
extract_devices(diode("DN"),                          # Floating Protection
                            { "P"  => (DN & BULK),    # P region
                              "N"  => (DN),           # N region
                              "tA" => (BULK),         # Terminal: Anode
                              "tC" => (DN) })         # Terminal: Cathode
#
tolerance("DN", "A", :relative => 0.05)               # 5% tolerance 
tolerance("DN", "P", :relative => 0.05)               # 5% tolerance 
#